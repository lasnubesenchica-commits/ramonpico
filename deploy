  var operCode =
'// ── CONSTANTES Operaciones.gs ─────────────────────────────────\n' +
'var SHEET_CV           = \'Compras_Ventas\';\n' +
'var EMAIL_COMPROBANTES = \'' + s.compEmail + '\';\n' +
'var CONFIANZA_MINIMA   = 70;\n' +
'var RUC_EMPRESA        = \'' + s.ruc + '\';\n\n';

  if (s.provNombre) {
