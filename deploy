</div>

<script>
// ═══════════════════════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════════════════════
var STATE = {
  step: 1,
  token: null,
  sheetId: null,
  folderId: null,
  sheetUrl: null,
  folderUrl: null,
  // form data
  negocio: '', ruc: '', dv: '', adminEmail: '', compEmail: '',
  waNum: '', itbms: '0.07', prefix: 'RP',
  provNombre: '', provRuc: '', provDv: '', provEmail: '', provFileId: '',
};

// ═══════════════════════════════════════════════════════════
//  NAVIGATION
// ═══════════════════════════════════════════════════════════
function goStep(n) {
  document.getElementById('step' + STATE.step).classList.remove('active');
  STATE.step = n;
  document.getElementById('step' + n).classList.add('active');
  updateProgress();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function updateProgress() {
  for (var i = 1; i <= 4; i++) {
    var seg = document.getElementById('ps' + i);
    seg.className = 'progress-seg' + (i < STATE.step ? ' done' : (i === STATE.step ? ' active' : ''));
  }
}

// ═══════════════════════════════════════════════════════════
//  STEP 1 → 2
// ═══════════════════════════════════════════════════════════
function goStep2() {
  var errors = [];
  var vals = {
    negocio:    document.getElementById('negocio').value.trim(),
    ruc:        document.getElementById('ruc').value.trim(),
    dv:         document.getElementById('dv').value.trim(),
    adminEmail: document.getElementById('adminEmail').value.trim(),
    compEmail:  document.getElementById('compEmail').value.trim(),
    waNum:      document.getElementById('waNum').value.trim(),
    itbms:      document.getElementById('itbms').value,
    prefix:     document.getElementById('prefix').value.trim().toUpperCase(),
    provNombre: document.getElementById('provNombre').value.trim(),
    provRuc:    document.getElementById('provRuc').value.trim(),
    provDv:     document.getElementById('provDv').value.trim(),
    provEmail:  document.getElementById('provEmail').value.trim(),
    provFileId: document.getElementById('provFileId').value.trim(),
  };

  if (!vals.negocio)    errors.push('Nombre del negocio es requerido');
  if (!vals.ruc)        errors.push('RUC es requerido');
  if (!vals.dv)         errors.push('DV es requerido');
  if (!vals.adminEmail) errors.push('Email admin es requerido');
  if (!vals.compEmail)  errors.push('Email comprobantes es requerido');
  if (!vals.prefix)     errors.push('Prefijo de IDs es requerido');

  var errEl = document.getElementById('err1');
  if (errors.length) {
    errEl.textContent = '⚠ ' + errors.join(' · ');
    errEl.style.display = 'flex';
    return;
  }
  errEl.style.display = 'none';
  Object.assign(STATE, vals);
  goStep(2);
}

// ═══════════════════════════════════════════════════════════
//  OAUTH
// ═══════════════════════════════════════════════════════════
function startOAuth() {
  var clientId = document.getElementById('clientId').value.trim();
  if (!clientId) {
    alert('Ingresá el Client ID de Google Cloud Console primero, o usá el token manual.');
    return;
  }
  var scopes = [
    'https://www.googleapis.com/auth/spreadsheets',
    'https://www.googleapis.com/auth/drive.file',
  ].join(' ');

  var redirectUri = window.location.origin || 'http://localhost';
  var url = 'https://accounts.google.com/o/oauth2/v2/auth' +
    '?client_id=' + encodeURIComponent(clientId) +
    '&redirect_uri=' + encodeURIComponent(redirectUri) +
    '&response_type=token' +
    '&scope=' + encodeURIComponent(scopes);

  var popup = window.open(url, 'oauth', 'width=500,height=600');

  // Escuchar el token del popup (implicit flow)
  var checkInterval = setInterval(function() {
    try {
      if (popup.closed) { clearInterval(checkInterval); return; }
      var hash = popup.location.hash;
      if (hash && hash.indexOf('access_token') !== -1) {
        clearInterval(checkInterval);
        popup.close();
        var params = new URLSearchParams(hash.substring(1));
        var token = params.get('access_token');
        if (token) setToken(token);
      }
    } catch(e) { /* cross-origin — seguir esperando */ }
  }, 500);
}

function useManualToken() {
  var token = document.getElementById('manualToken').value.trim();
  if (!token) { alert('Pegá el Access Token primero.'); return; }
  setToken(token);
}

function setToken(token) {
  STATE.token = token;
  var statusEl = document.getElementById('authStatus');
  statusEl.classList.add('show');
  document.getElementById('authStatusText').textContent = 'Token configurado — listo para crear recursos';
  document.getElementById('btnNext2').disabled = false;
}

// ═══════════════════════════════════════════════════════════
//  STEP 3: Crear Sheet + Folder
// ═══════════════════════════════════════════════════════════
async function goStep3() {
  goStep(3);
  var log = document.getElementById('logBody');
  log.innerHTML = '';

  function addLog(icon, text, sub, spin) {
    var line = document.createElement('div');
    line.className = 'log-line';
    line.innerHTML =
      (spin ? '<div class="spinner"></div>' : '<div class="log-icon">' + icon + '</div>') +
      '<div class="log-text"><div>' + text + '</div>' + (sub ? '<div class="log-sub">' + sub + '</div>' : '') + '</div>';
    log.appendChild(line);
    return line;
  }

  function updateLog(line, icon, text, sub) {
    line.innerHTML =
      '<div class="log-icon">' + icon + '</div>' +
      '<div class="log-text"><div>' + text + '</div>' + (sub ? '<div class="log-sub">' + sub + '</div>' : '') + '</div>';
  }

  // 1. Crear Google Sheet
  var l1 = addLog('', 'Creando Google Sheet...', '', true);
  await sleep(400);
  try {
    var sheetRes = await fetch('https://sheets.googleapis.com/v4/spreadsheets', {
      method: 'POST',
      headers: {
        'Authorization': 'Bearer ' + STATE.token,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        properties: { title: STATE.negocio + ' — Sistema Contable' },
      }),
    });
    var sheetData = await sheetRes.json();
    if (!sheetData.spreadsheetId) throw new Error(sheetData.error ? sheetData.error.message : 'Error desconocido');
    STATE.sheetId  = sheetData.spreadsheetId;
    STATE.sheetUrl = 'https://docs.google.com/spreadsheets/d/' + STATE.sheetId + '/edit';
    updateLog(l1, '✅', 'Google Sheet creado', STATE.sheetId);
  } catch(e) {
    updateLog(l1, '❌', 'Error creando Sheet: ' + e.message);
    return;
  }

  // 2. Crear carpeta Drive
  var l2 = addLog('', 'Creando carpeta en Drive...', '', true);
  await sleep(300);
  try {
    var folderRes = await fetch('https://www.googleapis.com/drive/v3/files', {
      method: 'POST',
      headers: {
        'Authorization': 'Bearer ' + STATE.token,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        name: 'Vouchers — ' + STATE.negocio,
        mimeType: 'application/vnd.google-apps.folder',
      }),
    });
    var folderData = await folderRes.json();
    if (!folderData.id) throw new Error(folderData.error ? folderData.error.message : 'Error desconocido');
    STATE.folderId  = folderData.id;
    STATE.folderUrl = 'https://drive.google.com/drive/folders/' + STATE.folderId;
    updateLog(l2, '✅', 'Carpeta Drive creada', STATE.folderId);
  } catch(e) {
    updateLog(l2, '❌', 'Error creando carpeta Drive: ' + e.message);
    return;
  }

  // 3. Hacer la carpeta pública
  var l3 = addLog('', 'Configurando permisos de la carpeta...', '', true);
  await sleep(300);
  try {
    await fetch('https://www.googleapis.com/drive/v3/files/' + STATE.folderId + '/permissions', {
      method: 'POST',
      headers: {
        'Authorization': 'Bearer ' + STATE.token,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({ role: 'reader', type: 'anyone' }),
    });
    updateLog(l3, '✅', 'Carpeta compartida como "cualquiera con el link puede ver"');
  } catch(e) {
    updateLog(l3, '⚠️', 'Permisos: ' + e.message + ' (hacelo manual en Drive)');
  }

  // 4. Done
  await sleep(200);
  addLog('🎉', 'Recursos creados exitosamente', 'Listo para generar el código GAS');

  // Mostrar resultados
  document.getElementById('res-sheetId').textContent  = STATE.sheetId;
  document.getElementById('res-folderId').textContent = STATE.folderId;
  document.getElementById('res-cliente').textContent  = STATE.negocio;
  document.getElementById('step3Results').style.display = 'block';
}

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

// ═══════════════════════════════════════════════════════════
//  STEP 4: Generar código
// ═══════════════════════════════════════════════════════════
function goStep4() {
  goStep(4);
  buildOutputs();
}

