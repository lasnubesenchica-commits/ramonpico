<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Provisioner — Nuevo Cliente</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Sora:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:       #0F0F0F;
    --surface:  #181818;
    --surface2: #222222;
    --border:   #2A2A2A;
    --border2:  #333333;
    --orange:   #E05A00;
    --orange2:  #FF7A20;
    --green:    #22C55E;
    --blue:     #3B82F6;
    --yellow:   #F59E0B;
    --red:      #EF4444;
    --text:     #F0F0F0;
    --muted:    #888888;
    --mono:     'DM Mono', monospace;
    --sans:     'Sora', sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    min-height: 100vh;
    padding: 0 0 80px;
  }

  /* ── HEADER ── */
  .header {
    border-bottom: 1px solid var(--border);
    padding: 20px 40px;
    display: flex;
    align-items: center;
    gap: 16px;
    position: sticky;
    top: 0;
    background: rgba(15,15,15,0.95);
    backdrop-filter: blur(8px);
    z-index: 100;
  }
  .header-logo {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--orange);
    letter-spacing: 3px;
    font-weight: 500;
  }
  .header-sep { color: var(--border2); }
  .header-title {
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 1px;
  }
  .header-badge {
    margin-left: auto;
    background: var(--surface2);
    border: 1px solid var(--border2);
    border-radius: 4px;
    padding: 4px 10px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
  }

  /* ── LAYOUT ── */
  .container {
    max-width: 820px;
    margin: 0 auto;
    padding: 40px 40px 0;
  }

  /* ── STEPS ── */
  .step {
    display: none;
    animation: fadeIn 0.3s ease;
  }
  .step.active { display: block; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

  /* ── STEP HEADER ── */
  .step-header {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 36px;
  }
  .step-num {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: var(--orange);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--mono);
    font-size: 16px;
    font-weight: 500;
    flex-shrink: 0;
  }
  .step-meta h2 {
    font-size: 22px;
    font-weight: 600;
    margin-bottom: 6px;
  }
  .step-meta p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
  }

  /* ── PROGRESS ── */
  .progress-bar {
    display: flex;
    gap: 6px;
    margin-bottom: 40px;
    padding-top: 8px;
  }
  .progress-seg {
    height: 3px;
    flex: 1;
    border-radius: 2px;
    background: var(--border2);
    transition: background 0.4s;
  }
  .progress-seg.done { background: var(--orange); }
  .progress-seg.active { background: var(--orange2); }

  /* ── FORM ── */
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .form-grid.full { grid-template-columns: 1fr; }
  .field { display: flex; flex-direction: column; gap: 7px; }
  .field.span2 { grid-column: span 2; }
  label {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }
  label .req { color: var(--orange); margin-left: 2px; }
  input, select, textarea {
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: 6px;
    padding: 11px 14px;
    font-family: var(--sans);
    font-size: 14px;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }
  input:focus, select:focus, textarea:focus {
    border-color: var(--orange);
  }
  input::placeholder { color: var(--muted); }
  select option { background: var(--surface2); }
  .field-hint {
    font-size: 11px;
    color: var(--muted);
    margin-top: -2px;
  }

  /* ── SECTION DIVIDER ── */
  .section-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 2px;
    text-transform: uppercase;
    border-bottom: 1px solid var(--border);
    padding-bottom: 8px;
    margin: 28px 0 20px;
  }

  /* ── OAUTH PANEL ── */
  .oauth-card {
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: 10px;
    padding: 32px;
    text-align: center;
  }
  .oauth-icon {
    width: 56px; height: 56px;
    background: var(--surface2);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px;
    font-size: 26px;
  }
  .oauth-card h3 { font-size: 18px; margin-bottom: 10px; }
  .oauth-card p { font-size: 13px; color: var(--muted); line-height: 1.7; max-width: 420px; margin: 0 auto 24px; }
  .oauth-scopes {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }
  .scope-tag {
    background: var(--surface2);
    border: 1px solid var(--border2);
    border-radius: 4px;
    padding: 4px 10px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
  }
  .auth-status {
    display: flex;
    align-items: center;
    gap: 10px;
    justify-content: center;
    margin-top: 20px;
    font-size: 13px;
    color: var(--green);
    display: none;
  }
  .auth-status.show { display: flex; }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: currentColor; }

  /* ── PROGRESS LOG ── */
  .log-panel {
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: 10px;
    overflow: hidden;
  }
  .log-header {
    background: var(--surface2);
    padding: 12px 18px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 1px;
    border-bottom: 1px solid var(--border);
  }
  .log-body {
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-height: 120px;
  }
  .log-line {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 13px;
    opacity: 0;
    animation: fadeIn 0.3s ease forwards;
  }
  .log-icon { font-size: 16px; flex-shrink: 0; }
  .log-text { flex: 1; }
  .log-sub {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    margin-top: 2px;
  }
  .spinner {
    width: 16px; height: 16px;
    border: 2px solid var(--border2);
    border-top-color: var(--orange);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── OUTPUT CARDS ── */
  .output-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .output-card {
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: 10px;
    overflow: hidden;
  }
  .output-card-header {
    background: var(--surface2);
    padding: 12px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
  }
  .output-card-title {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .output-card-title .file-icon { color: var(--orange); }
  .copy-btn {
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: 4px;
    padding: 5px 12px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.2s;
  }
  .copy-btn:hover { border-color: var(--orange); color: var(--orange); }
  .copy-btn.copied { border-color: var(--green); color: var(--green); }
  .code-block {
    padding: 16px 18px;
    font-family: var(--mono);
    font-size: 12px;
    line-height: 1.8;
    color: #CCC;
    overflow-x: auto;
    white-space: pre;
    max-height: 320px;
    overflow-y: auto;
  }
  .code-block::-webkit-scrollbar { width: 4px; height: 4px; }
  .code-block::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }
  .kw { color: #C792EA; }
  .str { color: #C3E88D; }
  .cmt { color: #546E7A; }
  .key { color: #82AAFF; }
  .val { color: #F78C6C; }

  /* ── STEPS CHECKLIST ── */
  .checklist {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border2);
    border-radius: 10px;
    overflow: hidden;
  }
  .check-item {
    display: flex;
    gap: 16px;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
    align-items: flex-start;
    transition: background 0.2s;
  }
  .check-item:last-child { border-bottom: none; }
  .check-item:hover { background: var(--surface); }
  .check-num {
    width: 26px; height: 26px;
    border-radius: 50%;
    border: 1px solid var(--border2);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    flex-shrink: 0;
    margin-top: 1px;
  }
  .check-num.done { background: var(--green); border-color: var(--green); color: #000; }
  .check-body { flex: 1; }
  .check-title { font-size: 14px; font-weight: 600; margin-bottom: 4px; }
  .check-desc { font-size: 12px; color: var(--muted); line-height: 1.6; }
  .check-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 8px;
    background: var(--surface2);
    border: 1px solid var(--border2);
    border-radius: 5px;
    padding: 6px 12px;
    font-size: 12px;
    color: var(--orange2);
    text-decoration: none;
    transition: border-color 0.2s;
  }
  .check-link:hover { border-color: var(--orange); }

  /* ── BUTTONS ── */
  .btn-row {
    display: flex;
    gap: 12px;
    margin-top: 32px;
    justify-content: flex-end;
  }
  .btn {
    padding: 12px 28px;
    border-radius: 7px;
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
  }
  .btn-primary {
    background: var(--orange);
    color: #fff;
  }
  .btn-primary:hover { background: var(--orange2); }
  .btn-primary:disabled { background: var(--border2); color: var(--muted); cursor: not-allowed; }
  .btn-secondary {
    background: transparent;
    border: 1px solid var(--border2);
    color: var(--muted);
  }
  .btn-secondary:hover { border-color: var(--text); color: var(--text); }
  .btn-ghost {
    background: transparent;
    border: 1px solid var(--green);
    color: var(--green);
    font-family: var(--mono);
    font-size: 12px;
    padding: 10px 20px;
  }
  .btn-ghost:hover { background: var(--green); color: #000; }

  /* ── ALERT ── */
  .alert {
    padding: 12px 16px;
    border-radius: 7px;
    font-size: 13px;
    margin-bottom: 20px;
    display: flex;
    gap: 10px;
    align-items: flex-start;
    display: none;
  }
  .alert.show { display: flex; }
  .alert-error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #FCA5A5; }
  .alert-info  { background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.3); color: #93C5FD; }
  .alert-warn  { background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.3); color: #FCD34D; }

  /* ── SUMMARY BANNER ── */
  .summary-banner {
    background: linear-gradient(135deg, rgba(224,90,0,0.15), rgba(224,90,0,0.05));
    border: 1px solid rgba(224,90,0,0.3);
    border-radius: 10px;
    padding: 24px;
    margin-bottom: 28px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .summary-item { text-align: center; }
  .summary-label { font-family: var(--mono); font-size: 10px; color: var(--muted); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px; }
  .summary-val { font-size: 15px; font-weight: 600; color: var(--orange2); }
  .summary-val.small { font-size: 12px; font-family: var(--mono); }

  /* ── CLIENT ID DISPLAY ── */
  .id-display {
    background: var(--surface2);
    border: 1px solid var(--border2);
    border-radius: 6px;
    padding: 8px 14px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--orange2);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  /* ── GOOGLE OAUTH CLIENT CONFIG ── */
  .config-note {
    background: var(--surface2);
    border-left: 3px solid var(--yellow);
    padding: 14px 18px;
    border-radius: 0 6px 6px 0;
    font-size: 13px;
    color: #DDD;
    line-height: 1.7;
    margin-bottom: 20px;
  }
  .config-note code {
    font-family: var(--mono);
    font-size: 11px;
    background: var(--surface);
    padding: 2px 6px;
    border-radius: 3px;
    color: var(--orange2);
  }

  @media (max-width: 600px) {
    .container { padding: 24px 20px 0; }
    .form-grid { grid-template-columns: 1fr; }
    .field.span2 { grid-column: span 1; }
    .summary-banner { grid-template-columns: 1fr; }
    .header { padding: 16px 20px; }
  }
</style>
</head>
<body>

<div class="header">
  <span class="header-logo">RP.SISTEMA</span>
  <span class="header-sep">·</span>
  <span class="header-title">PROVISIONER</span>
  <span class="header-badge">v1.0 · developer</span>
</div>

<div class="container">

  <!-- PROGRESS -->
  <div class="progress-bar">
    <div class="progress-seg active" id="ps1"></div>
    <div class="progress-seg" id="ps2"></div>
    <div class="progress-seg" id="ps3"></div>
    <div class="progress-seg" id="ps4"></div>
  </div>

  <!-- ═══════════ STEP 1: Datos del cliente ═══════════ -->
  <div class="step active" id="step1">
    <div class="step-header">
      <div class="step-num">1</div>
      <div class="step-meta">
        <h2>Datos del cliente</h2>
        <p>Ingresá la información del negocio. Estos valores van a quedar embebidos en el código GAS generado.</p>
      </div>
    </div>

    <div class="alert alert-error show" id="err1" style="display:none"></div>

    <div class="section-label">Identidad del negocio</div>
    <div class="form-grid">
      <div class="field span2">
        <label>Nombre del negocio <span class="req">*</span></label>
        <input type="text" id="negocio" placeholder="Ej: Distribuidora Perez S.A." />
      </div>
      <div class="field">
        <label>RUC de la empresa <span class="req">*</span></label>
        <input type="text" id="ruc" placeholder="8-123-456789" />
        <span class="field-hint">RUC del emisor (Círculo Financiero análogo)</span>
      </div>
      <div class="field">
        <label>DV <span class="req">*</span></label>
        <input type="text" id="dv" placeholder="45" maxlength="3"/>
        <span class="field-hint">Dígito verificador</span>
      </div>
      <div class="field">
        <label>Email admin <span class="req">*</span></label>
        <input type="email" id="adminEmail" placeholder="admin@empresa.com" />
        <span class="field-hint">Recibe emails de órdenes</span>
      </div>
      <div class="field">
        <label>Email comprobantes <span class="req">*</span></label>
        <input type="email" id="compEmail" placeholder="admin+comprobantes@empresa.com" />
        <span class="field-hint">Label Gmail para sync automático</span>
      </div>
      <div class="field">
        <label>WhatsApp (con código de país)</label>
        <input type="text" id="waNum" placeholder="50766724615" />
      </div>
      <div class="field">
        <label>ITBMS</label>
        <select id="itbms">
          <option value="0.07">7% (estándar Panamá)</option>
          <option value="0.10">10%</option>
          <option value="0">Exento</option>
        </select>
      </div>
    </div>

    <div class="section-label">Proveedor principal</div>
    <div class="form-grid">
      <div class="field span2">
        <label>Nombre del proveedor</label>
        <input type="text" id="provNombre" placeholder="Empresas Carbone S.A." />
        <span class="field-hint">Proveedor de quien comprás para revender (o dejá vacío si no aplica)</span>
      </div>
      <div class="field">
        <label>RUC del proveedor</label>
        <input type="text" id="provRuc" placeholder="1080323-1-554308" />
      </div>
      <div class="field">
        <label>DV del proveedor</label>
        <input type="text" id="provDv" placeholder="54" maxlength="3"/>
      </div>
      <div class="field">
        <label>Email del proveedor (para sync)</label>
        <input type="text" id="provEmail" placeholder="facturas@carbone.com.pa" />
        <span class="field-hint">Opcional — para detectar facturas entrantes</span>
      </div>
      <div class="field">
        <label>Identificador en nombre de archivo</label>
        <input type="text" id="provFileId" placeholder="1080323" />
        <span class="field-hint">Parte del nombre de archivo de sus facturas PDF/XML</span>
      </div>
    </div>

    <div class="section-label">Configuración de Google Drive</div>
    <div class="form-grid">
      <div class="field span2">
        <label>Prefijo de IDs del sistema <span class="req">*</span></label>
        <input type="text" id="prefix" placeholder="RP" maxlength="8"/>
        <span class="field-hint">Ej: "RP" → IDs serán ING-RP-2025-0001. Usá 2-4 letras del cliente.</span>
      </div>
    </div>

    <div class="btn-row">
      <button class="btn btn-primary" onclick="goStep2()">Continuar →</button>
    </div>
  </div>

  <!-- ═══════════ STEP 2: Autenticación Google ═══════════ -->
  <div class="step" id="step2">
    <div class="step-header">
      <div class="step-num">2</div>
      <div class="step-meta">
        <h2>Autenticación Google</h2>
        <p>Necesitamos tu token OAuth para crear el Google Sheet y la carpeta en Drive. El token queda solo en tu browser.</p>
      </div>
    </div>

    <div class="config-note">
      <strong>⚠️ Requisito: Google OAuth Client ID</strong><br>
      Para que el popup de Google funcione, necesitás un <strong>OAuth Client ID</strong> configurado en Google Cloud Console con:<br>
      → Tipo: <code>Web application</code><br>
      → Authorized JavaScript origins: <code>file://</code> (si abrís el HTML local) o tu dominio si está hosteado<br><br>
      Si no tenés uno, el campo de abajo acepta también un <strong>Access Token directo</strong> (más rápido para uso personal).
    </div>

    <div class="oauth-card">
      <div class="oauth-icon">🔑</div>
      <h3>Autorizá con Google</h3>
      <p>El provisioner va a crear el Google Sheet y la carpeta de Drive en tu cuenta (o la cuenta que uses para el cliente).</p>
      <div class="oauth-scopes">
        <span class="scope-tag">sheets.spreadsheets</span>
        <span class="scope-tag">drive.file</span>
      </div>

      <div style="margin-bottom:20px">
        <label style="display:block;margin-bottom:8px;font-size:11px;color:var(--muted);letter-spacing:1px;text-transform:uppercase">OAuth Client ID (o dejá vacío para token manual)</label>
        <input type="text" id="clientId" placeholder="xxxx.apps.googleusercontent.com" style="margin-bottom:12px"/>
        <button class="btn btn-primary" id="btnOauth" onclick="startOAuth()" style="width:100%">Conectar con Google →</button>
      </div>

      <div style="color:var(--muted);font-size:12px;margin:12px 0">— o —</div>

      <div>
        <label style="display:block;margin-bottom:8px;font-size:11px;color:var(--muted);letter-spacing:1px;text-transform:uppercase">Pegar Access Token directamente</label>
        <input type="text" id="manualToken" placeholder="ya29.a0AfH6SM..." style="font-family:var(--mono);font-size:12px"/>
        <button class="btn btn-secondary" onclick="useManualToken()" style="width:100%;margin-top:10px">Usar este token</button>
        <div style="font-size:11px;color:var(--muted);margin-top:6px">Obtenelo en <a href="https://developers.google.com/oauthplayground" target="_blank" style="color:var(--orange2)">OAuth 2.0 Playground</a> con scopes: drive.file y spreadsheets</div>
      </div>

      <div class="auth-status" id="authStatus">
        <div class="dot"></div>
        <span id="authStatusText">Autenticado correctamente</span>
      </div>
    </div>

    <div class="btn-row">
      <button class="btn btn-secondary" onclick="goStep(1)">← Atrás</button>
      <button class="btn btn-primary" id="btnNext2" disabled onclick="goStep3()">Crear recursos →</button>
    </div>
  </div>

  <!-- ═══════════ STEP 3: Creación automática ═══════════ -->
  <div class="step" id="step3">
    <div class="step-header">
      <div class="step-num">3</div>
      <div class="step-meta">
        <h2>Creando recursos</h2>
        <p>El provisioner está creando el Google Sheet y la carpeta de Drive para el cliente.</p>
      </div>
    </div>

    <div class="log-panel">
      <div class="log-header">PROVISIONER LOG</div>
      <div class="log-body" id="logBody"></div>
    </div>

    <div id="step3Results" style="display:none;margin-top:24px">
      <div class="summary-banner">
        <div class="summary-item">
          <div class="summary-label">Google Sheet</div>
          <div class="summary-val small" id="res-sheetId">—</div>
        </div>
        <div class="summary-item">
          <div class="summary-label">Drive Folder</div>
          <div class="summary-val small" id="res-folderId">—</div>
        </div>
        <div class="summary-item">
          <div class="summary-label">Cliente</div>
          <div class="summary-val" id="res-cliente">—</div>
        </div>
      </div>
      <div class="btn-row" style="margin-top:0">
        <button class="btn btn-primary" onclick="goStep4()">Generar código GAS →</button>
      </div>
    </div>
  </div>

  <!-- ═══════════ STEP 4: Código generado ═══════════ -->
  <div class="step" id="step4">
    <div class="step-header">
      <div class="step-num">4</div>
      <div class="step-meta">
        <h2>Código generado</h2>
        <p>Todo listo. Copiá cada bloque al editor de Apps Script y seguí los pasos finales.</p>
      </div>
    </div>

    <!-- Output cards -->
    <div class="output-grid" id="outputGrid">
      <!-- Se genera dinámicamente -->
    </div>

    <div class="section-label" style="margin-top:32px">Pasos finales manuales</div>

    <div class="checklist" id="checklist">
      <!-- Se genera dinámicamente -->
    </div>

    <div class="btn-row">
      <button class="btn btn-ghost" onclick="restart()">⟳ Provisionar otro cliente</button>
    </div>
