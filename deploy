      '<div class="check-num' + (item.done ? ' done' : '') + '">' + (item.done ? '✓' : (i + 1)) + '</div>' +
      '<div class="check-body">' +
        '<div class="check-title">' + item.title + '</div>' +
        '<div class="check-desc">' + item.desc + '</div>' +
        (item.link ? '<a class="check-link" href="' + item.link + '" target="_blank">' + item.linkText + ' ↗</a>' : '') +
      '</div>';
    checklist.appendChild(div);
  });
}

function addOutputCard(parent, title, subtitle, code) {
  var card = document.createElement('div');
  card.className = 'output-card';
  var id = 'code_' + Math.random().toString(36).substr(2, 6);
  card.innerHTML =
    '<div class="output-card-header">' +
      '<div class="output-card-title">' +
        '<span class="file-icon">◈</span> ' + title +
      '</div>' +
      '<button class="copy-btn" onclick="copyCode(\'' + id + '\', this)">Copiar</button>' +
    '</div>' +
    (subtitle ? '<div style="padding:8px 18px;font-size:12px;color:var(--muted);border-bottom:1px solid var(--border)">' + subtitle + '</div>' : '') +
    '<div class="code-block" id="' + id + '">' + escapeHtml(code) + '</div>';
  parent.appendChild(card);
}

function copyCode(id, btn) {
  var text = document.getElementById(id).textContent;
  navigator.clipboard.writeText(text).then(function() {
    btn.textContent = '✓ Copiado';
    btn.className = 'copy-btn copied';
    setTimeout(function() {
      btn.textContent = 'Copiar';
      btn.className = 'copy-btn';
    }, 2000);
  }).catch(function() {
    var ta = document.createElement('textarea');
    ta.value = text;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    btn.textContent = '✓ Copiado';
    btn.className = 'copy-btn copied';
    setTimeout(function() { btn.textContent = 'Copiar'; btn.className = 'copy-btn'; }, 2000);
  });
}

function escapeHtml(str) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function restart() {
  STATE = {
    step: 1, token: null, sheetId: null, folderId: null,
    sheetUrl: null, folderUrl: null,
    negocio: '', ruc: '', dv: '', adminEmail: '', compEmail: '',
    waNum: '', itbms: '0.07', prefix: 'RP',
    provNombre: '', provRuc: '', provDv: '', provEmail: '', provFileId: '',
  };
  // Reset form
  ['negocio','ruc','dv','adminEmail','compEmail','waNum','prefix',
   'provNombre','provRuc','provDv','provEmail','provFileId','manualToken','clientId'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.value = '';
  });
  document.getElementById('itbms').value = '0.07';
  document.getElementById('authStatus').classList.remove('show');
  document.getElementById('btnNext2').disabled = true;
  document.getElementById('logBody').innerHTML = '';
  document.getElementById('step3Results').style.display = 'none';

  goStep(1);
}
