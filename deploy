'// Proveedor principal\n' +
'var PROV_NOMBRE = \'' + s.provNombre + '\';\n' +
'var PROV_RUC    = \'' + s.provRuc + '\';\n' +
'var PROV_DV     = \'' + s.provDv + '\';\n';
    if (s.provFileId) {
