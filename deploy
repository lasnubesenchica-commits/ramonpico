'// ── Buscar y reemplazar en TODO el proyecto GAS ───────────────\n' +
'//\n' +
'// Reemplazos en Operaciones.gs (referencias hardcodeadas):\n' +
'// \'Empresas Carbone S.A.\'    →  \'' + (s.provNombre || '[PROVEEDOR]') + '\'\n' +
'// \'1080323-1-554308\'        →  \'' + (s.provRuc || '[RUC_PROV]') + '\'\n' +
'// dv_prov: \'54\'              →  \'' + (s.provDv || '[DV_PROV]') + '\'\n' +
'// \'1753684-1-696883\'        →  \'' + s.ruc + '-1-XXXXX\'  // RUC completo tuyo\n' +
'// \'CIRCULO FINANCIERO\'      →  \'' + s.negocio.toUpperCase().split(' ')[0] + '\'\n' +
'// \'lasnubesenchica\'         →  tu email sin @\n' +
'//\n' +
'// IDs generados (prefijo ' + s.prefix + '):\n' +
'// \'ING-RP-\'  →  \'ING-' + s.prefix + '-\'\n' +
'// \'EGR-RP-\'  →  \'EGR-' + s.prefix + '-\'\n' +
'// \'CV-\'      →  \'CV-' + s.prefix + '-\'  (opcional)\n' +
'// \'ST-RP-\'   →  \'ST-' + s.prefix + '-\'\n' +
'// \'COT-RP-\'  →  \'COT-' + s.prefix + '-\'';

  addOutputCard(grid,
    '🔍 Guía de búsqueda y reemplazo',
    'Hacé Ctrl+H en el editor GAS para reemplazar estas referencias en todos los archivos',
    idsCode
  );

  // ── Bloque 4: Admin HTML placeholder ──────────────────
  var adminCode =
'<!-- En adminv2.html — buscar GAS_URL y reemplazar por la URL del deploy -->\n' +
'<script>\n' +
'  // ⬇ Esta línea la encontrás en la parte superior del admin HTML\n' +
'  var GAS_URL = \'[PEGAR_URL_WEB_APP_AQUI]\';\n' +
'  // var CLIENTE = \'' + s.negocio + '\';\n' +
'  // var PREFIX  = \'' + s.prefix + '\';\n' +
'<\/script>\n\n' +
'<!-- Si querés cambiar el título y color de marca -->\n' +
'<!-- Buscar "RAMON.PICO" y reemplazar por el nombre del cliente -->';

  addOutputCard(grid,
    '🌐 adminv2.html — URL del Web App',
    'Después del deploy GAS copiá la URL aquí',
    adminCode
  );

  // ── Checklist ──────────────────────────────────────────
  var checklist = document.getElementById('checklist');
  checklist.innerHTML = '';

  var checkItems = [
    {
      done: true,
      title: 'Google Sheet creado',
      desc: 'ID: ' + s.sheetId,
      link: s.sheetUrl,
      linkText: 'Abrir Sheet →'
    },
    {
      done: true,
      title: 'Carpeta Drive creada',
      desc: 'ID: ' + s.folderId + ' · Permisos configurados como público con el link',
      link: s.folderUrl,
      linkText: 'Abrir carpeta →'
    },
    {
